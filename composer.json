{
    "name": "respatch/respatch-bundle",
    "type": "symfony-bundle",
    "license": "MIT",
    "description": "Acme bundle description",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.5",
        "opis/json-schema": "^2.6",
        "symfony/framework-bundle": "^6.4|^7.4|^8.0",
        "zenstruck/messenger-monitor-bundle": "^0.6.0"
    },
    "config": {
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "Respatch\\RespatchBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Respatch\\RespatchBundle\\Tests\\": "tests/"
        }
    }
}
